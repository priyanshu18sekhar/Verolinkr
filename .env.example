# ── Copy to .env.local and fill in. Never commit real secrets. ──

# Firebase client (browser) — from Firebase Console → Project settings → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin (server) — from a service account JSON
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_DATABASE_ID=

# ── Social connect (optional) ──────────────────────────────────────────
# Leave BLANK to run platform connections in demo mode (realistic simulated
# data so the whole app works now). Fill these in to flip Instagram/Facebook
# and YouTube to real OAuth — no code change needed.
#
# Meta (Instagram + Facebook): developers.facebook.com → create an app,
# add Facebook Login, set the OAuth redirect URI to:
#   https://YOUR_DOMAIN/api/connect/instagram/callback
#   https://YOUR_DOMAIN/api/connect/facebook/callback
META_CLIENT_ID=
META_CLIENT_SECRET=
#
# Google (YouTube): console.cloud.google.com → OAuth client (Web), enable the
# YouTube Data API v3, set the redirect URI to:
#   https://YOUR_DOMAIN/api/connect/youtube/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Razorpay Standard Web Checkout ─────────────────────────────────────
# dashboard.razorpay.com → Settings → API Keys. Use rzp_test_* keys until
# launch, then swap for live keys. The secret is server-only — never give
# it a NEXT_PUBLIC_ prefix.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Public key id for the browser checkout (key id ONLY, same value as above).
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# ── Admin console (/admin) ─────────────────────────────────────────────
# Comma-separated emails that may access the admin control center.
# (You can also set profiles/{uid}.role = "admin" in Firestore.)
ADMIN_EMAILS=
